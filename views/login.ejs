<%- include('partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <h2 class="auth-title">Вход</h2>
    <form id="loginForm" class="auth-form">
      <div class="form-group">
        <label>Логин или Email</label>
        <input type="text" name="username" class="form-input" placeholder="Введите логин или email" required>
      </div>
      <div class="form-group">
        <label>Пароль</label>
        <input type="password" name="password" class="form-input" placeholder="Введите пароль" required>
      </div>
      <div id="authError" class="auth-error"></div>
      <button type="submit" class="btn-submit">
        <i class="fas fa-arrow-right"></i> Войти
      </button>
    </form>
    <p class="auth-link">Нет аккаунта? <a href="/register">Зарегистрироваться</a></p>
  </div>
</div>

<%- include('partials/footer') %>
