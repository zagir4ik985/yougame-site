<%- include('partials/header') %>

<section class="settings-page">
  <div class="container">
    <h1 class="page-title"><i class="fas fa-download"></i> Мои загрузки</h1>

    <% if (downloads.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-box-open"></i>
        <p>У вас пока нет загрузок</p>
        <a href="/" class="btn-buy"><i class="fas fa-arrow-left"></i> На главную</a>
      </div>
    <% } else { %>
      <div class="downloads-list">
        <% downloads.forEach(d => { %>
          <div class="download-item">
            <div class="download-item-icon">
              <i class="fas fa-cube"></i>
            </div>
            <div class="download-item-body">
              <h3><%= d.title %></h3>
              <span class="download-date"><i class="far fa-clock"></i> <%= new Date(d.downloaded_at).toLocaleString('ru-RU') %></span>
            </div>
            <a href="/product/<%= d.id %>" class="btn-submit btn-sm">
              <i class="fas fa-eye"></i>
            </a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
