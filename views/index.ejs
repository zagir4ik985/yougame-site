<%- include('partials/header') %>
<div class="hero glass-hero">
  <h1 class="hero-title">Майнкрафт Клиенты</h1>
  <p class="hero-subtitle">Скачивай лучшие сборки бесплатно</p>
  <div class="hero-search glass-input-wrapper">
    <i class="fas fa-search"></i>
    <input type="text" id="searchInput" placeholder="Поиск клиентов..." class="glass-input">
  </div>
</div>

<div class="container">
  <div class="category-filters">
    <button class="filter-btn active" data-category="all">Все</button>
    <% categories.forEach(cat => { %>
      <button class="filter-btn" data-category="<%= cat %>"><%= cat %></button>
    <% }) %>
  </div>

  <div class="products-grid" id="productsGrid">
    <% products.forEach(product => { %>
      <a href="/product/<%= product.id %>" class="product-card glass-card">
        <div class="product-card-img">
          <i class="fas fa-cubes"></i>
        </div>
        <div class="product-card-body">
          <h3 class="product-card-title"><%= product.title %></h3>
          <p class="product-card-desc"><%= product.description?.substring(0, 80) %><%= product.description?.length > 80 ? '...' : '' %></p>
          <div class="product-card-meta">
            <span class="badge"><%= product.version %></span>
            <span class="download-count"><i class="fas fa-download"></i> <%= product.downloads %></span>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</div>
<%- include('partials/footer') %>
