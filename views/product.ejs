<%- include('partials/header') %>

<section class="product-page">
  <div class="container">
    <div class="product-hero">
      <div class="product-image">
        <img src="/images/logo.png" alt="zagaDLC">
      </div>
      <div class="product-info">
        <h1><%= product.title %></h1>
        <div class="product-meta">
          <span class="product-tag"><%= product.version %></span>
          <span class="product-tag" style="background:rgba(124,92,252,0.15);color:var(--accent-secondary);border-color:rgba(124,92,252,0.2);">Fabric</span>
          <span class="product-downloads"><i class="fas fa-download"></i> <%= product.downloads %> загрузок</span>
        </div>
        <p class="product-description"><%= product.description %></p>

        <div class="product-features-list">
          <div class="product-feature-item"><i class="fas fa-check"></i> TriggerBot</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> KillAura</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> ESP / Tracers</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> Criticals</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> Fly / Speed</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> GuiMove</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> View Model</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> Fullbright</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> Scaffold</div>
          <div class="product-feature-item"><i class="fas fa-check"></i> Velocity</div>
        </div>

        <div class="hero-actions" style="justify-content:flex-start;">
          <a href="https://funpay.com/lots/offer?id=72031571" target="_blank" class="btn-buy">
            <i class="fas fa-shopping-cart"></i> Купить за 250₽
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
